# compose 用環境変数 (このファイルを .env にコピーして値を設定する。 .env は git 管理外にすること)
# UBI9 + OpenJDK21 + JBoss EAP 8.1 導入済みの社内ベースイメージ
EAP_BASE_IMAGE=your-registry.example.com/base/eap81-openjdk21-ubi9:latest
# ローカル専用のダミーパスワード (本番の値を書かないこと)
APPDB_PASSWORD="ChangeMe_APPDB_P@ss123"
INFDB_PASSWORD="ChangeMe_INFDB_P@ss123"
MYSQL_ROOT_PASSWORD=localdev-root-change-me
